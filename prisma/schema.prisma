// Prisma schema — defines your database structure.
// Run `npm run db:push` after any changes here to update the actual database.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Customer info — filled in by Stripe after payment
  customerName  String
  customerEmail String

  // What they ordered
  size  String  // "4x5", "6x8", or "8x10"
  rush  Boolean @default(false)
  notes String? // Optional, hence the ?

  // Photo — one or both may be provided
  photoFilename String? // Cloudinary secure URL of the uploaded photo
  photoLink     String? // Google Drive / Dropbox URL

  // Payment
  stripeSessionId String @unique // Links this order back to Stripe
  amountPaid      Int    // In cents (e.g. 4900 = $49.00)
  paymentStatus   String @default("pending") // "pending" | "paid" | "failed"

  // Fulfillment — this is what you update in the admin dashboard
  status String @default("Pending") // "Pending" | "Printing" | "Shipped" | "Complete"
}
