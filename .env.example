# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Cloudinary (photo uploads) ──────────────────────────────────────────────
# Get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
ADMIN_PASSWORD=your-strong-password-here

# ─── App URL (for Stripe redirect URLs) ──────────────────────────────────────
# Set this to your live Netlify domain after deploying
NEXT_PUBLIC_BASE_URL=https://your-site.netlify.app
