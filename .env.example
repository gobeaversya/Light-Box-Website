# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/test/apikeys
# Use the "test" keys while developing — they start with sk_test_ and pk_test_
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Get this by running: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Then copy the "whsec_..." secret it prints
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
# Choose any strong password. This is what you'll type to access /admin
ADMIN_PASSWORD=your-admin-password-here

# ─── App URL (for Stripe redirect URLs) ──────────────────────────────────────
# Leave as-is for local development. Change to your live domain when deploying.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
